pdlr:entity_heavy_trucks pdl:dependsOn pdlr:entity_adblue_supply .

pdlr:dependency_urea_adblue_chain_2 a pdl:Dependency ;
    pdl:fromEntity pdlr:entity_delivery_vans ;
    pdl:toEntity pdlr:entity_adblue_supply ;
    pdl:dependencyType "input" ;
    pdl:dependencyTypeRef pdl:DependencyType_input ;
    pdl:criticality pdl:Criticality_medium ;
    pdl:belongsToChain pdlr:chain_urea_adblue_chain .

# Direct dependency relationship
pdlr:entity_delivery_vans pdl:dependsOn pdlr:entity_adblue_supply .

pdlr:chain_fertilizer_chain a pdl:SupplyChain ;
    dcterms:identifier "fertilizer_chain" ;
    rdfs:label "Düngemittel-Landwirtschafts-Kette" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:connection_fertilizer_chain_1 a pdl:SupplyChainConnection ;
    pdl:sequence 1 ;
    pdl:fromEntity pdlr:entity_ammonia_supply ;
    pdl:toEntity pdlr:entity_nitrogen_fertilizer ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_nitrogen_fertilizer coy:hasSupplier pdlr:entity_ammonia_supply .
pdlr:entity_ammonia_supply coy:hasCustomer pdlr:entity_nitrogen_fertilizer .

pdlr:connection_fertilizer_chain_2 a pdl:SupplyChainConnection ;
    pdl:sequence 2 ;
    pdl:fromEntity pdlr:entity_ammonia_supply ;
    pdl:toEntity pdlr:entity_ammonium_nitrate ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_ammonium_nitrate coy:hasSupplier pdlr:entity_ammonia_supply .
pdlr:entity_ammonia_supply coy:hasCustomer pdlr:entity_ammonium_nitrate .

pdlr:connection_fertilizer_chain_3 a pdl:SupplyChainConnection ;
    pdl:sequence 3 ;
    pdl:fromEntity pdlr:entity_nitrogen_fertilizer ;
    pdl:toEntity pdlr:entity_agriculture_grain ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_agriculture_grain coy:hasSupplier pdlr:entity_nitrogen_fertilizer .
pdlr:entity_nitrogen_fertilizer coy:hasCustomer pdlr:entity_agriculture_grain .

pdlr:connection_fertilizer_chain_4 a pdl:SupplyChainConnection ;
    pdl:sequence 4 ;
    pdl:fromEntity pdlr:entity_nitrogen_fertilizer ;
    pdl:toEntity pdlr:entity_agriculture_vegetables ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_agriculture_vegetables coy:hasSupplier pdlr:entity_nitrogen_fertilizer .
pdlr:entity_nitrogen_fertilizer coy:hasCustomer pdlr:entity_agriculture_vegetables .

pdlr:connection_fertilizer_chain_5 a pdl:SupplyChainConnection ;
    pdl:sequence 5 ;
    pdl:fromEntity pdlr:entity_ammonium_nitrate ;
    pdl:toEntity pdlr:entity_agriculture_grain ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_agriculture_grain coy:hasSupplier pdlr:entity_ammonium_nitrate .
pdlr:entity_ammonium_nitrate coy:hasCustomer pdlr:entity_agriculture_grain .

pdlr:connection_fertilizer_chain_6 a pdl:SupplyChainConnection ;
    pdl:sequence 6 ;
    pdl:fromEntity pdlr:entity_agriculture_grain ;
    pdl:toEntity pdlr:entity_food_retail ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_food_retail coy:hasSupplier pdlr:entity_agriculture_grain .
pdlr:entity_agriculture_grain coy:hasCustomer pdlr:entity_food_retail .

pdlr:connection_fertilizer_chain_7 a pdl:SupplyChainConnection ;
    pdl:sequence 7 ;
    pdl:fromEntity pdlr:entity_agriculture_vegetables ;
    pdl:toEntity pdlr:entity_food_retail ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_food_retail coy:hasSupplier pdlr:entity_agriculture_vegetables .
pdlr:entity_agriculture_vegetables coy:hasCustomer pdlr:entity_food_retail .

pdlr:connection_fertilizer_chain_8 a pdl:SupplyChainConnection ;
    pdl:sequence 8 ;
    pdl:fromEntity pdlr:entity_food_retail ;
    pdl:toEntity pdlr:entity_consumers ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# CoyPu-compatible supplier relationship
pdlr:entity_consumers coy:hasSupplier pdlr:entity_food_retail .
pdlr:entity_food_retail coy:hasCustomer pdlr:entity_consumers .

pdlr:dependency_fertilizer_chain_1 a pdl:Dependency ;
    pdl:fromEntity pdlr:entity_agriculture_grain ;
    pdl:toEntity pdlr:entity_nitrogen_fertilizer ;
    pdl:dependencyType "input" ;
    pdl:dependencyTypeRef pdl:DependencyType_input ;
    pdl:criticality pdl:Criticality_high ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# Direct dependency relationship
pdlr:entity_agriculture_grain pdl:dependsOn pdlr:entity_nitrogen_fertilizer .

pdlr:dependency_fertilizer_chain_2 a pdl:Dependency ;
    pdl:fromEntity pdlr:entity_agriculture_vegetables ;
    pdl:toEntity pdlr:entity_nitrogen_fertilizer ;
    pdl:dependencyType "input" ;
    pdl:dependencyTypeRef pdl:DependencyType_input ;
    pdl:criticality pdl:Criticality_high ;
    pdl:belongsToChain pdlr:chain_fertilizer_chain .

# Direct dependency relationship
pdlr:entity_agriculture_vegetables pdl:dependsOn pdlr:entity_nitrogen_fertilizer .

# =============================================================================
# Events
# =============================================================================

pdlr:event_gas_price_spike a pdl:Event, pdl:Event_MarketShock ;
    dcterms:identifier "gas_price_spike" ;
    rdfs:label "Erdgas-Preisexplosion" ;
    pdl:eventType "market_shock" ;
    pdl:triggerTarget pdlr:entity_natural_gas_supply ;
    coy:hasImpactOn pdlr:entity_natural_gas_supply ;
    pdl:triggerProbability "0.2"^^xsd:decimal ;
    pdl:impactPrice "+300%" ;
    pdl:impactDuration "60d" ;
    pdl:causes pdlr:event_ammonia_production_halt ;
    dcterms:source "Gaskrise 2022: Erdgaspreis-Peak 350 EUR/MWh (vs. 20 EUR normal)" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_gas_supply_disruption a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "gas_supply_disruption" ;
    rdfs:label "Erdgas-Lieferunterbrechung" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_natural_gas_supply ;
    coy:hasImpactOn pdlr:entity_natural_gas_supply ;
    pdl:triggerProbability "0.1"^^xsd:decimal ;
    pdl:impactSupply "-40%" ;
    pdl:impactDuration "60d" ;
    pdl:causes pdlr:event_ammonia_production_halt ;
    dcterms:source "Pipeline-Schaden oder geopolitische Unterbrechung" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_ammonia_production_halt a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "ammonia_production_halt" ;
    rdfs:label "Ammoniak-Produktionsstopp" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_basf_ludwigshafen ;
    coy:hasImpactOn pdlr:entity_basf_ludwigshafen ;
    pdl:triggerCondition "gas_price_spike.active OR gas_supply_disruption.active" ;
    pdl:impactSupply "-65%" ;
    pdl:impactDuration "45d" ;
    pdl:causes pdlr:event_co2_shortage, pdlr:event_urea_shortage ;
    dcterms:source "NH3-Produktionskürzung EU 2022: -70%" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_co2_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "co2_shortage" ;
    rdfs:label "CO2-Mangel" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_co2_industrial ;
    coy:hasImpactOn pdlr:entity_co2_industrial ;
    pdl:triggerCondition "ammonia_production_halt.active" ;
    pdl:impactSupply "-70%" ;
    pdl:impactDuration "30d" ;
    pdl:causes pdlr:event_slaughterhouse_shutdown, pdlr:event_beverage_shortage, pdlr:event_packaging_shortage ;
    dcterms:source "1,5 t CO2 pro t NH3 - CO2 ist Nebenprodukt" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_slaughterhouse_shutdown a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "slaughterhouse_shutdown" ;
    rdfs:label "Schlachtbetriebe stoppen" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_slaughterhouses ;
    coy:hasImpactOn pdlr:entity_slaughterhouses ;
    pdl:triggerCondition "co2_shortage.active" ;
    pdl:impactSupply "-80%" ;
    pdl:impactDuration "21d" ;
    pdl:causes pdlr:event_meat_shortage ;
    dcterms:source "CO2-Engpass UK 2021: Schlachtbetriebe 3 Wochen geschlossen" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_beverage_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "beverage_shortage" ;
    rdfs:label "Getränkeproduktion eingeschränkt" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_beverage_industry ;
    coy:hasImpactOn pdlr:entity_beverage_industry ;
    pdl:triggerCondition "co2_shortage.active" ;
    pdl:impactSupply "-50%" ;
    pdl:impactDuration "30d" ;
    dcterms:source "CO2 für Kohlensäure in Bier, Mineralwasser, Softdrinks" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_packaging_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "packaging_shortage" ;
    rdfs:label "Lebensmittelverpackung eingeschränkt" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_food_packaging ;
    coy:hasImpactOn pdlr:entity_food_packaging ;
    pdl:triggerCondition "co2_shortage.active" ;
    pdl:impactSupply "-60%" ;
    pdl:impactDuration "21d" ;
    dcterms:source "MAP-Verpackung (Modified Atmosphere Packaging) benötigt CO2" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_meat_shortage a pdl:Event, pdl:Event_MarketShock ;
    dcterms:identifier "meat_shortage" ;
    rdfs:label "Fleischknappheit" ;
    pdl:eventType "market_shock" ;
    pdl:triggerTarget pdlr:entity_food_retail ;
    coy:hasImpactOn pdlr:entity_food_retail ;
    pdl:triggerCondition "slaughterhouse_shutdown.active" ;
    pdl:impactSupply "-25%" ;
    pdl:impactPrice "+35%" ;
    pdl:impactDuration "60d" ;
    dcterms:source "Tierwohl-Krise durch Verarbeitungsstopp" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_urea_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "urea_shortage" ;
    rdfs:label "Harnstoff-Mangel" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_urea_supply ;
    coy:hasImpactOn pdlr:entity_urea_supply ;
    pdl:triggerCondition "ammonia_production_halt.active" ;
    pdl:impactSupply "-60%" ;
    pdl:impactDuration "45d" ;
    pdl:causes pdlr:event_adblue_shortage, pdlr:event_fertilizer_shortage ;
    dcterms:source "Harnstoff Hauptrohstoff für AdBlue und Stickstoffdünger" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_adblue_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "adblue_shortage" ;
    rdfs:label "AdBlue-Knappheit" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_adblue_supply ;
    coy:hasImpactOn pdlr:entity_adblue_supply ;
    pdl:triggerCondition "urea_shortage.active" ;
    pdl:impactSupply "-55%" ;
    pdl:impactDuration "60d" ;
    pdl:causes pdlr:event_truck_logistics_breakdown ;
    dcterms:source "AdBlue-Verbrauch DE ~1,2 Mio. t/Jahr, >6 Mio. LKW betroffen" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_truck_logistics_breakdown a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "truck_logistics_breakdown" ;
    rdfs:label "LKW-Logistik bricht ein" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_heavy_trucks ;
    coy:hasImpactOn pdlr:entity_heavy_trucks ;
    pdl:triggerCondition "adblue_shortage.active" ;
    pdl:impactSupply "-40%" ;
    pdl:impactDuration "90d" ;
    pdl:causes pdlr:event_supply_chain_disruption ;
    dcterms:source "Euro-6-Fahrzeuge ohne AdBlue gehen in Notlauf" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_supply_chain_disruption a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "supply_chain_disruption" ;
    rdfs:label "Lieferketten-Zusammenbruch" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_food_retail ;
    coy:hasImpactOn pdlr:entity_food_retail ;
    pdl:triggerCondition "truck_logistics_breakdown.active" ;
    pdl:impactSupply "-30%" ;
    pdl:impactDuration "60d" ;
    dcterms:source "Lebensmittelversorgung abhängig von LKW-Transport" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_fertilizer_shortage a pdl:Event, pdl:Event_MarketShock ;
    dcterms:identifier "fertilizer_shortage" ;
    rdfs:label "Düngemittelmangel" ;
    pdl:eventType "market_shock" ;
    pdl:triggerTarget pdlr:entity_nitrogen_fertilizer ;
    coy:hasImpactOn pdlr:entity_nitrogen_fertilizer ;
    pdl:triggerCondition "urea_shortage.active" ;
    pdl:impactSupply "-50%" ;
    pdl:impactPrice "+200%" ;
    pdl:impactDuration "180d" ;
    pdl:causes pdlr:event_crop_yield_reduction ;
    dcterms:source "Düngerpreise 2022: +200% (vs. 2021)" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_crop_yield_reduction a pdl:Event, pdl:Event_NaturalDisaster, coy:Disaster ;
    dcterms:identifier "crop_yield_reduction" ;
    rdfs:label "Ertragseinbruch Landwirtschaft" ;
    pdl:eventType "natural_disaster" ;
    pdl:triggerTarget pdlr:entity_agriculture_grain ;
    coy:hasImpactOn pdlr:entity_agriculture_grain ;
    pdl:triggerCondition "fertilizer_shortage.active" ;
    pdl:impactSupply "-40%" ;
    pdl:impactDuration "365d" ;
    pdl:causes pdlr:event_food_price_spike ;
    dcterms:source "Ohne Dünger: Ertragsrückgang 40-50%" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:event_food_price_spike a pdl:Event, pdl:Event_MarketShock ;
    dcterms:identifier "food_price_spike" ;
    rdfs:label "Nahrungsmittelpreis-Explosion" ;
    pdl:eventType "market_shock" ;
    pdl:triggerTarget pdlr:entity_consumers ;
    coy:hasImpactOn pdlr:entity_consumers ;
    pdl:triggerCondition "crop_yield_reduction.active" ;
    pdl:impactPrice "+40%" ;
    pdl:impactDuration "365d" ;
    dcterms:source "Kombinierte Effekte aus Fleisch-, Gemüse- und Getreideknappheit" ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

# CoyPu-compatible inverse impact relationships
pdlr:entity_natural_gas_supply coy:isImpactedBy pdlr:event_gas_price_spike .
pdlr:entity_natural_gas_supply coy:isImpactedBy pdlr:event_gas_supply_disruption .
pdlr:entity_basf_ludwigshafen coy:isImpactedBy pdlr:event_ammonia_production_halt .
pdlr:entity_co2_industrial coy:isImpactedBy pdlr:event_co2_shortage .
pdlr:entity_slaughterhouses coy:isImpactedBy pdlr:event_slaughterhouse_shutdown .
pdlr:entity_beverage_industry coy:isImpactedBy pdlr:event_beverage_shortage .
pdlr:entity_food_packaging coy:isImpactedBy pdlr:event_packaging_shortage .
pdlr:entity_food_retail coy:isImpactedBy pdlr:event_meat_shortage .
pdlr:entity_urea_supply coy:isImpactedBy pdlr:event_urea_shortage .
pdlr:entity_adblue_supply coy:isImpactedBy pdlr:event_adblue_shortage .
pdlr:entity_heavy_trucks coy:isImpactedBy pdlr:event_truck_logistics_breakdown .
pdlr:entity_food_retail coy:isImpactedBy pdlr:event_supply_chain_disruption .
pdlr:entity_nitrogen_fertilizer coy:isImpactedBy pdlr:event_fertilizer_shortage .
pdlr:entity_agriculture_grain coy:isImpactedBy pdlr:event_crop_yield_reduction .
pdlr:entity_consumers coy:isImpactedBy pdlr:event_food_price_spike .

# =============================================================================
# Cascades
# =============================================================================

pdlr:cascade_co2_food_cascade a pdl:Cascade ;
    dcterms:identifier "co2_food_cascade" ;
    rdfs:label "CO2-Lebensmittel-Kaskade" ;
    pdl:originEvent pdlr:event_gas_price_spike ;
    pdl:probability "0.85"^^xsd:decimal ;
    dcterms:source "UK CO2-Krise 2021, Gaskrise 2022" ;
    pdl:validationConfidence "0.9"^^xsd:decimal ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:timeline_co2_food_cascade_1 a pdl:TimelineEntry ;
    pdl:sequence 1 ;
    pdl:atTime "0d" ;
    pdl:timelineEvent pdlr:event_gas_price_spike ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "energy" ;
    pdl:impactSeverity pdl:Severity_high .

pdlr:timeline_co2_food_cascade_2 a pdl:TimelineEntry ;
    pdl:sequence 2 ;
    pdl:atTime "7d" ;
    pdl:timelineEvent pdlr:event_ammonia_production_halt ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "chemistry" ;
    pdl:impactSeverity pdl:Severity_critical ;
    pdl:affects pdlr:entity_basf_ludwigshafen, pdlr:entity_skw_piesteritz, pdlr:entity_yara_brunsbuettel, pdlr:entity_ineos_koeln .

pdlr:timeline_co2_food_cascade_3 a pdl:TimelineEntry ;
    pdl:sequence 3 ;
    pdl:atTime "10d" ;
    pdl:timelineEvent pdlr:event_co2_shortage ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "chemistry" ;
    pdl:impactSeverity pdl:Severity_critical ;
    pdl:affects pdlr:entity_co2_industrial .

pdlr:timeline_co2_food_cascade_4 a pdl:TimelineEntry ;
    pdl:sequence 4 ;
    pdl:atTime "14d" ;
    pdl:timelineEvent pdlr:event_slaughterhouse_shutdown ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "food" ;
    pdl:impactSeverity pdl:Severity_critical ;
    pdl:affects pdlr:entity_slaughterhouses .

pdlr:timeline_co2_food_cascade_5 a pdl:TimelineEntry ;
    pdl:sequence 5 ;
    pdl:atTime "14d" ;
    pdl:timelineEvent pdlr:event_beverage_shortage ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "food" ;
    pdl:impactSeverity pdl:Severity_high ;
    pdl:affects pdlr:entity_beverage_industry .

pdlr:timeline_co2_food_cascade_6 a pdl:TimelineEntry ;
    pdl:sequence 6 ;
    pdl:atTime "14d" ;
    pdl:timelineEvent pdlr:event_packaging_shortage ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "food" ;
    pdl:impactSeverity pdl:Severity_high ;
    pdl:affects pdlr:entity_food_packaging .

pdlr:timeline_co2_food_cascade_7 a pdl:TimelineEntry ;
    pdl:sequence 7 ;
    pdl:atTime "21d" ;
    pdl:timelineEvent pdlr:event_meat_shortage ;
    pdl:belongsToCascade pdlr:cascade_co2_food_cascade ;
    pdl:impactSector "retail" ;
    pdl:impactSeverity pdl:Severity_high ;
    pdl:affects pdlr:entity_food_retail, pdlr:entity_consumers .

pdlr:cascade_adblue_logistics_cascade a pdl:Cascade ;
    dcterms:identifier "adblue_logistics_cascade" ;
    rdfs:label "AdBlue-Logistik-Kaskade" ;
    pdl:originEvent pdlr:event_gas_price_spike ;
    pdl:probability "0.8"^^xsd:decimal ;
    dcterms:source "AdBlue-Knappheit 2021/2022" ;
    pdl:validationConfidence "0.85"^^xsd:decimal ;
    pdl:partOfScenario pdlr:scenario_fertilizer_adblue_disruption .

pdlr:timeline_adblue_logistics_cascade_1 a pdl:TimelineEntry ;
    pdl:sequence 1 ;
    pdl:atTime "0d" ;
    pdl:timelineEvent pdlr:event_gas_price_spike ;
    pdl:belongsToCascade pdlr:cascade_adblue_logistics_cascade ;
    pdl:impactSector "energy" ;
    pdl:impactSeverity pdl:Severity_high .

pdlr:timeline_adblue_logistics_cascade_2 a pdl:TimelineEntry ;
    pdl:sequence 2 ;
    pdl:atTime "14d" ;
    pdl:timelineEvent pdlr:event_ammonia_production_halt ;
    pdl:belongsToCascade pdlr:cascade_adblue_logistics_cascade ;
    pdl:impactSector "chemistry" ;
    pdl:impactSeverity pdl:Severity_critical .

pdlr:timeline_adblue_logistics_cascade_3 a pdl:TimelineEntry ;
    pdl:sequence 3 ;
    pdl:atTime "21d" ;
    pdl:timelineEvent pdlr:event_urea_shortage ;
    pdl:belongsToCascade pdlr:cascade_adblue_logistics_cascade ;
    pdl:impactSector "chemistry" ;
    pdl:impactSeverity pdl:Severity_critical ;
    pdl:affects pdlr:entity_urea_supply .

pdlr:timeline_adblue_logistics_cascade_4 a pdl:TimelineEntry ;
    pdl:sequence 4 ;
    pdl:atTime "28d" ;
    pdl:timelineEvent pdlr:event_adblue_shortage ;
    pdl:belongsToCascade pdlr:cascade_adblue_logistics_cascade ;
    pdl:impactSector "chemistry" ;
