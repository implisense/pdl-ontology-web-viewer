# =============================================================================
# Scenario: Rechenzentren und digitale Verwaltung
# =============================================================================

pdlr:scenario_datacenter_disruption a pdl:Scenario ;
    dcterms:identifier "datacenter_disruption" ;
    rdfs:label "Rechenzentren und digitale Verwaltung" ;
    pdl:sector "it" ;
    pdl:criticality pdl:Criticality_high ;
    dcterms:description "Simulation der Kaskadeneffekte eines regionalen Stromausfalls auf Rechenzentren in der Frankfurt Rhein-Main Region. Rechenzentren haben USV-Autonomie von 10-30 Minuten und Diesel-Notstrom für 24-72 Stunden. DE-CIX Frankfurt wickelt ca. 40% des deutschen Internetverkehrs ab. Betroffen: Öffentliche Verwaltung, Finanzsektor, Gesundheitswesen, Logistik und Kommunikation.\n" ;
    pdl:pdlVersion "1.1" .

