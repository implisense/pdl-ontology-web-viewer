# =============================================================================
# Events
# =============================================================================

pdlr:event_regional_blackout a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "regional_blackout" ;
    rdfs:label "Regionaler Stromausfall" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_power_grid_frankfurt ;
    coy:hasImpactOn pdlr:entity_power_grid_frankfurt ;
    pdl:triggerProbability "0.05"^^xsd:decimal ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "96h" ;
    pdl:causes pdlr:event_ups_takeover ;
    dcterms:source "Großflächiger Stromausfall durch Extremwetterereignis" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_ups_takeover a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "ups_takeover" ;
    rdfs:label "USV übernimmt Stromversorgung" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_ups_systems ;
    coy:hasImpactOn pdlr:entity_ups_systems ;
    pdl:triggerCondition "regional_blackout.active" ;
    pdl:impactSupply "-0%" ;
    pdl:impactDuration "30m" ;
    pdl:causes pdlr:event_ups_depleted ;
    dcterms:source "Automatische USV-Umschaltung in <0.01 Sekunden" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_ups_depleted a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "ups_depleted" ;
    rdfs:label "USV-Kapazität erschöpft" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_ups_systems ;
    coy:hasImpactOn pdlr:entity_ups_systems ;
    pdl:triggerCondition "ups_takeover.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "96h" ;
    pdl:causes pdlr:event_diesel_generators_start ;
    dcterms:source "USV-Autonomie: 10-30 Minuten" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_diesel_generators_start a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "diesel_generators_start" ;
    rdfs:label "Notstromaggregate gestartet" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_diesel_generators ;
    coy:hasImpactOn pdlr:entity_diesel_generators ;
    pdl:triggerCondition "ups_depleted.active" ;
    pdl:impactSupply "-0%" ;
    pdl:impactDuration "48h" ;
    pdl:causes pdlr:event_diesel_shortage ;
    dcterms:source "Diesel-Notstrom-Reichweite: 24-72 Stunden" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_diesel_shortage a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "diesel_shortage" ;
    rdfs:label "Diesel-Nachschub kritisch" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_diesel_supply ;
    coy:hasImpactOn pdlr:entity_diesel_supply ;
    pdl:triggerCondition "diesel_generators_start.active" ;
    pdl:impactSupply "-80%" ;
    pdl:impactDuration "72h" ;
    pdl:causes pdlr:event_datacenter_shutdown_tsystems, pdlr:event_datacenter_shutdown_interxion ;
    dcterms:source "Tanklaster bei Blackout nicht verfügbar" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_datacenter_shutdown_tsystems a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "datacenter_shutdown_tsystems" ;
    rdfs:label "T-Systems Frankfurt heruntergefahren" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_tsystems_frankfurt ;
    coy:hasImpactOn pdlr:entity_tsystems_frankfurt ;
    pdl:triggerCondition "diesel_shortage.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "72h" ;
    pdl:causes pdlr:event_government_services_offline ;
    dcterms:source "T-Systems: 24h Diesel-Vorrat" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_datacenter_shutdown_interxion a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "datacenter_shutdown_interxion" ;
    rdfs:label "Interxion Frankfurt heruntergefahren" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_interxion_frankfurt ;
    coy:hasImpactOn pdlr:entity_interxion_frankfurt ;
    pdl:triggerCondition "diesel_shortage.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "60h" ;
    pdl:causes pdlr:event_healthcare_it_offline ;
    dcterms:source "Interxion: 36h Diesel-Vorrat" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_datacenter_shutdown_equinix a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "datacenter_shutdown_equinix" ;
    rdfs:label "Equinix Frankfurt heruntergefahren" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_equinix_frankfurt ;
    coy:hasImpactOn pdlr:entity_equinix_frankfurt ;
    pdl:triggerCondition "diesel_shortage.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "48h" ;
    pdl:causes pdlr:event_payment_systems_offline ;
    dcterms:source "Equinix: 48h Diesel-Vorrat" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_datacenter_shutdown_decix a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "datacenter_shutdown_decix" ;
    rdfs:label "DE-CIX Frankfurt heruntergefahren" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_decix_frankfurt ;
    coy:hasImpactOn pdlr:entity_decix_frankfurt ;
    pdl:triggerCondition "diesel_shortage.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "24h" ;
    pdl:causes pdlr:event_internet_disruption ;
    dcterms:source "DE-CIX: 72h Diesel-Vorrat, 40% deutscher Internetverkehr" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_cooling_failure a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "cooling_failure" ;
    rdfs:label "Kühlungsausfall" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_cooling_systems ;
    coy:hasImpactOn pdlr:entity_cooling_systems ;
    pdl:triggerCondition "regional_blackout.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "60m" ;
    pdl:causes pdlr:event_thermal_shutdown ;
    dcterms:source "Ohne Kühlung: kritische Temperatur nach 30-45 Min." ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_thermal_shutdown a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "thermal_shutdown" ;
    rdfs:label "Thermische Notabschaltung" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_decix_frankfurt ;
    coy:hasImpactOn pdlr:entity_decix_frankfurt ;
    pdl:triggerCondition "cooling_failure.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "48h" ;
    dcterms:source "Automatischer Shutdown bei >35°C zum Schutz der Hardware" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_government_services_offline a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "government_services_offline" ;
    rdfs:label "OZG-Dienste offline" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_ozg_services ;
    coy:hasImpactOn pdlr:entity_ozg_services ;
    pdl:triggerCondition "datacenter_shutdown_tsystems.active" ;
    pdl:impactSupply "-100%" ;
    pdl:impactDuration "72h" ;
    pdl:causes pdlr:event_citizen_services_disrupted ;
    dcterms:source ">600 Online-Verwaltungsdienste betroffen" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_payment_systems_offline a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "payment_systems_offline" ;
    rdfs:label "Zahlungsverkehr gestört" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_payment_systems ;
    coy:hasImpactOn pdlr:entity_payment_systems ;
    pdl:triggerCondition "datacenter_shutdown_equinix.active" ;
    pdl:impactSupply "-80%" ;
    pdl:impactDuration "48h" ;
    pdl:causes pdlr:event_retail_cash_only ;
    dcterms:source "SEPA, Kartenzahlungen, Online-Banking betroffen" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_healthcare_it_offline a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "healthcare_it_offline" ;
    rdfs:label "Krankenhaus-IT ausgefallen" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_hospital_it ;
