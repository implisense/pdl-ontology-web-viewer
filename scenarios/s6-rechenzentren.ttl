    pdl:triggerCondition "datacenter_shutdown_interxion.active" ;
    pdl:impactSupply "-70%" ;
    pdl:impactDuration "48h" ;
    pdl:causes pdlr:event_emergency_protocols ;
    dcterms:source "Patientensicherheit gefährdet, Papier-Fallback aktiviert" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_internet_disruption a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "internet_disruption" ;
    rdfs:label "Internet-Störung national" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_network_carriers ;
