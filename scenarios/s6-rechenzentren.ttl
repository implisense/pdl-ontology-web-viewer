# CoyPu-compatible inverse impact relationships
pdlr:entity_power_grid_frankfurt coy:isImpactedBy pdlr:event_regional_blackout .
pdlr:entity_ups_systems coy:isImpactedBy pdlr:event_ups_takeover .
pdlr:entity_ups_systems coy:isImpactedBy pdlr:event_ups_depleted .
pdlr:entity_diesel_generators coy:isImpactedBy pdlr:event_diesel_generators_start .
pdlr:entity_diesel_supply coy:isImpactedBy pdlr:event_diesel_shortage .
pdlr:entity_tsystems_frankfurt coy:isImpactedBy pdlr:event_datacenter_shutdown_tsystems .
pdlr:entity_interxion_frankfurt coy:isImpactedBy pdlr:event_datacenter_shutdown_interxion .
pdlr:entity_equinix_frankfurt coy:isImpactedBy pdlr:event_datacenter_shutdown_equinix .
pdlr:entity_decix_frankfurt coy:isImpactedBy pdlr:event_datacenter_shutdown_decix .
pdlr:entity_cooling_systems coy:isImpactedBy pdlr:event_cooling_failure .
pdlr:entity_decix_frankfurt coy:isImpactedBy pdlr:event_thermal_shutdown .
pdlr:entity_ozg_services coy:isImpactedBy pdlr:event_government_services_offline .
pdlr:entity_payment_systems coy:isImpactedBy pdlr:event_payment_systems_offline .
pdlr:entity_hospital_it coy:isImpactedBy pdlr:event_healthcare_it_offline .
pdlr:entity_network_carriers coy:isImpactedBy pdlr:event_internet_disruption .
pdlr:entity_retail_pos coy:isImpactedBy pdlr:event_retail_cash_only .
pdlr:entity_emergency_dispatch coy:isImpactedBy pdlr:event_emergency_protocols .
pdlr:entity_voip_systems coy:isImpactedBy pdlr:event_communication_breakdown .
pdlr:entity_citizens coy:isImpactedBy pdlr:event_citizen_services_disrupted .
pdlr:entity_logistics_control coy:isImpactedBy pdlr:event_logistics_disruption .

# =============================================================================
# Cascades
# =============================================================================

pdlr:cascade_blackout_datacenter_cascade a pdl:Cascade ;
    dcterms:identifier "blackout_datacenter_cascade" ;
    rdfs:label "Blackout-Rechenzentren-Kaskade" ;
    pdl:originEvent pdlr:event_regional_blackout ;
    pdl:probability "0.9"^^xsd:decimal ;
    dcterms:source "Basiert auf PROVIDER-Szenarien-Dokumentation, Szenario 6" ;
    pdl:validationConfidence "0.85"^^xsd:decimal ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:timeline_blackout_datacenter_cascade_1 a pdl:TimelineEntry ;
    pdl:sequence 1 ;
    pdl:atTime "0h" ;
    pdl:timelineEvent pdlr:event_regional_blackout ;
    pdl:belongsToCascade pdlr:cascade_blackout_datacenter_cascade ;
    pdl:impactSector "energy" ;
    pdl:impactSeverity pdl:Severity_critical ;
    pdl:affects pdlr:entity_power_grid_frankfurt .

pdlr:timeline_blackout_datacenter_cascade_2 a pdl:TimelineEntry ;
    pdl:sequence 2 ;
    pdl:atTime "0h" ;
    pdl:timelineEvent pdlr:event_ups_takeover ;
    pdl:belongsToCascade pdlr:cascade_blackout_datacenter_cascade ;
