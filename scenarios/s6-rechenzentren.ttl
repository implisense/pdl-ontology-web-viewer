    pdl:causes pdlr:event_communication_breakdown ;
    dcterms:source "DE-CIX: zentraler Internet-Austauschpunkt" ;
    pdl:partOfScenario pdlr:scenario_datacenter_disruption .

pdlr:event_retail_cash_only a pdl:Event, pdl:Event_MarketShock ;
