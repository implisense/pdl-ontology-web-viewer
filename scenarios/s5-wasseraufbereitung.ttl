# =============================================================================
# Events
# =============================================================================

pdlr:event_electricity_price_spike a pdl:Event, pdl:Event_MarketShock ;
    dcterms:identifier "electricity_price_spike" ;
    rdfs:label "Strompreisexplosion" ;
    pdl:eventType "market_shock" ;
    pdl:triggerTarget pdlr:entity_electricity_grid ;
    coy:hasImpactOn pdlr:entity_electricity_grid ;
    pdl:triggerProbability "0.15"^^xsd:decimal ;
    pdl:impactPrice "+300%" ;
    pdl:impactDuration "45d" ;
    pdl:causes pdlr:event_chlorine_production_halt ;
    dcterms:source "Strompreis >400 EUR/MWh führt zu Produktionsstopps" ;
    pdl:partOfScenario pdlr:scenario_water_treatment_disruption .

pdlr:event_chlorine_production_halt a pdl:Event, pdl:Event_InfrastructureFailure ;
    dcterms:identifier "chlorine_production_halt" ;
    rdfs:label "Chlorproduktionsstopp" ;
    pdl:eventType "infrastructure_failure" ;
    pdl:triggerTarget pdlr:entity_basf_ludwigshafen ;
